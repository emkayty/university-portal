# University Portal - Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values
# DO NOT commit this file to version control!
# ============================================================

# ============================================================
# APPLICATION
# ============================================================
APP_NAME=University Portal
APP_URL=http://localhost:3000
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-at-least-50-characters-long

# ============================================================
# DATABASE
# ============================================================
DB_NAME=university_portal
DB_USER=postgres
DB_PASSWORD=postgres123
DB_HOST=localhost
DB_PORT=5432

# ============================================================
# REDIS
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ============================================================
# RABBITMQ
# ============================================================
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672

# ============================================================
# CENTRIFUGO (Real-time)
# ============================================================
CENTRIFUGO_SECRET=centrifugo-secret-key-change-in-production
CENTRIFUGO_ADMIN_SECRET=centrifugo-admin-secret-key-change
CENTRIFUGO_URL=http://localhost:8001
CENTRIFUGO_PORT=8001

# ============================================================
# EMAIL/SMTP
# ============================================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=noreply@university.edu.ng

# ============================================================
# SMS (Nigeria)
# ============================================================
SMS_API_KEY=
SMS_SENDER=UNIVERSITY
SMS_ENDPOINT=https://api.termii.com

# ============================================================
# NIGERIAN GOVERNMENT APIs
# ============================================================

# JAMB (Joint Admissions and Matriculation Board)
JAMB_API_URL=https://caps.jamb.gov.ng/api
JAMB_API_KEY=
JAMB_INSTITUTION_CODE=

# NIMC (National Identity Management Commission)
NIMC_API_URL=https://nimc.gov.ng/api
NIMC_API_KEY=
NIMC_SERVICE_ID=

# NYSC (National Youth Service Corps)
NYSC_API_URL=https://portal.nysc.org.ng/api
NYSC_API_KEY=

# ============================================================
# PAYMENT GATEWAYS (Nigeria)
# ============================================================

# Remita
REMITA_API_KEY=
REMITA_API_URL=https://remitademo.net
REMITA_MERCHANT_ID=
REMITA_SERVICE_TYPE_ID=

# Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

# Flutterwave
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=

# ============================================================
# CORS
# ============================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================
# AI/ML
# ============================================================
OPENAI_API_KEY=
HF_TOKEN=
ANTHROPIC_API_KEY=

# ============================================================
# AUTHENTICATION
# ============================================================
JWT_SECRET_KEY=your-jwt-secret-key-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_LIFETIME=60
REFRESH_TOKEN_LIFETIME=1440

# ============================================================
# FILE STORAGE
# ============================================================
MEDIA_ROOT=/app/media
MEDIA_URL=/media/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
SENTRY_DSN=
