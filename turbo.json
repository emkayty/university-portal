{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "build/**"],
      "env": ["NODE_ENV", "DATABASE_URL", "REDIS_URL"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "outputs": ["dist/**", ".next/**"]
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"],
      "env": ["NODE_ENV", "DATABASE_URL"]
    },
    "type-check": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "generate:types": {
      "dependsOn": ["^build"],
      "outputs": ["packages/api-client/src/generated/**"],
      "inputs": ["apps/api/**/openapi.json"]
    },
    "db:migrate": {
      "cache": false,
      "outputs": []
    },
    "db:seed": {
      "cache": false,
      "dependsOn": ["db:migrate"],
      "outputs": []
    },
    "clean": {
      "cache": false,
      "outputs": ["dist/**", ".next/**", "build/**", "coverage/**"]
    }
  }
}
